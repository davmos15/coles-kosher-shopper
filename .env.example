# --- Recipe extraction (server-side only, never exposed to the browser) ---
# Set at least one provider. If both are set we use Gemini (free tier) unless
# you pin a choice with EXTRACTION_PROVIDER.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx      # paid — https://console.anthropic.com
GEMINI_API_KEY=                        # free tier — https://aistudio.google.com/apikey

# Optional overrides:
# EXTRACTION_PROVIDER=gemini           # force "gemini" or "anthropic"
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# GEMINI_MODEL=gemini-2.0-flash

# --- Coles product search (optional, experimental) ---
# Default is link-only (each item links to a Coles search). Set to "live" to try
# real product search via Coles' internal endpoint — works from a home IP but is
# usually blocked from cloud hosts (e.g. Vercel), and is search-only (no cart).
# COLES_PROVIDER=live

# --- Phase 2 (sharing between two people) — leave blank to run local-only ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
